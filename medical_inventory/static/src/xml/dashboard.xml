<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">
<t t-name="medical_inventory.Dashboard">
<div class="o_med_dash">

    <t t-if="state.loading">
        <div class="o_med_center">
            <div class="o_med_spinner"/>
            <p>Loading dashboard...</p>
        </div>
    </t>

    <t t-if="state.error">
        <div class="o_med_center">
            <div style="font-size:48px;margin-bottom:12px">⚠️</div>
            <h3>Could not load dashboard</h3>
            <p style="color:#94a3b8">Please refresh the page.</p>
            <button class="o_med_btn o_btn_primary" t-on-click="() => this.loadData()">Retry</button>
        </div>
    </t>

    <t t-if="!state.loading and !state.error and state.data">

        <div class="o_med_header">
            <div>
                <h1>🏥 Medical Inventory</h1>
                <p>Real-time overview · <t t-esc="state.data.locations.length"/> locations tracked</p>
            </div>
            <div class="o_med_hbtns">
                <button class="o_med_btn o_btn_primary"
                    t-on-click="() => this.navigateTo('medical_inventory.action_stock_receive')">
                    📥 Receive Stock
                </button>
                <button class="o_med_btn o_btn_success"
                    t-on-click="() => this.navigateTo('medical_inventory.action_consumption_request')">
                    📤 New Request
                </button>
            </div>
        </div>

        <!-- KPI Cards -->
        <div class="o_kpi_row">
            <div class="o_kpi o_kpi_blue"
                t-on-click="() => this.navigateTo('medical_inventory.action_medical_stock_overview')">
                <div class="o_kpi_ico">📦</div>
                <div class="o_kpi_val"><t t-esc="fmt(state.data.total_products)"/></div>
                <div class="o_kpi_lbl">Products in Stock</div>
                <div class="o_kpi_sub"><t t-esc="fmt(state.data.total_qty)"/> total units</div>
            </div>
            <div class="o_kpi o_kpi_green"
                t-on-click="() => this.navigateTo('medical_inventory.action_receive_analytics')">
                <div class="o_kpi_ico">💰</div>
                <div class="o_kpi_val">$<t t-esc="fmtMoney(state.data.total_value)"/></div>
                <div class="o_kpi_lbl">Total Stock Value</div>
                <div class="o_kpi_sub">Click for purchase analytics</div>
            </div>
            <div class="o_kpi o_kpi_orange"
                t-on-click="() => this.navigateTo('medical_inventory.action_consumption_request')">
                <div class="o_kpi_ico">📋</div>
                <div class="o_kpi_val"><t t-esc="state.data.pending_requests"/></div>
                <div class="o_kpi_lbl">Pending Approvals</div>
                <div class="o_kpi_sub"><t t-esc="state.data.approved_requests"/> approved &amp; waiting</div>
            </div>
            <div class="o_kpi o_kpi_red"
                t-on-click="() => this.navigateTo('medical_inventory.action_expiry_monitor')">
                <div class="o_kpi_ico">⏰</div>
                <div class="o_kpi_val"><t t-esc="state.data.expired_count + state.data.critical_count"/></div>
                <div class="o_kpi_lbl">Expiry Alerts</div>
                <div class="o_kpi_sub"><t t-esc="state.data.expired_count"/> expired · <t t-esc="state.data.critical_count"/> in 5 days</div>
            </div>
        </div>

        <!-- Locations + Expiry -->
        <div class="o_med_row2">
            <div class="o_panel">
                <div class="o_panel_hd">
                    <h3>📍 Stock by Location</h3>
                    <button class="o_panel_link"
                        t-on-click="() => this.navigateTo('medical_inventory.action_medical_stock_overview')">
                        View All →
                    </button>
                </div>
                <t t-if="state.data.locations.length === 0">
                    <div class="o_empty">No stock found. Use Receive Stock to add items.</div>
                </t>
                <t t-foreach="state.data.locations" t-as="loc" t-key="loc.name">
                    <div class="o_loc_row">
                        <div class="o_loc_info">
                            <span class="o_loc_nm"><t t-esc="loc.name"/></span>
                            <span class="o_loc_sub"><t t-esc="loc.product_count"/> products · $<t t-esc="fmtMoney(loc.total_value)"/></span>
                        </div>
                        <div class="o_bar_wrap">
                            <div class="o_bar" t-attf-style="width:#{barPct(loc.total_qty, state.data.locations[0].total_qty)}"/>
                        </div>
                        <span class="o_loc_qty"><t t-esc="fmt(loc.total_qty)"/></span>
                    </div>
                </t>
            </div>

            <div class="o_panel">
                <div class="o_panel_hd">
                    <h3>⚠️ Expiry Monitor</h3>
                    <button class="o_panel_link"
                        t-on-click="() => this.navigateTo('medical_inventory.action_expiry_monitor')">
                        View All →
                    </button>
                </div>
                <t t-if="state.data.expiry_items.length === 0">
                    <div class="o_empty o_all_good">✅ All items within safe expiry range</div>
                </t>
                <t t-foreach="state.data.expiry_items" t-as="item" t-key="item.product + item.expiry">
                    <div t-attf-class="o_exp_row #{item.expired ? 'o_exp_dead' : 'o_exp_warn'}">
                        <div t-attf-class="o_exp_tag #{item.expired ? 'o_tag_red' : 'o_tag_orange'}">
                            <t t-if="item.expired">EXPIRED</t>
                            <t t-else=""><t t-esc="item.days_left"/>d left</t>
                        </div>
                        <div class="o_exp_body">
                            <span class="o_exp_prod"><t t-esc="item.product"/></span>
                            <span class="o_exp_meta">Qty <t t-esc="item.qty"/> · <t t-esc="item.location"/> · <t t-esc="item.expiry"/></span>
                        </div>
                    </div>
                </t>
            </div>
        </div>

        <!-- Chart + Top Products -->
        <div class="o_med_row3">
            <div class="o_panel o_chart_panel">
                <div class="o_panel_hd"><h3>📊 Monthly Spend (Last 6 Months)</h3></div>
                <canvas id="o_spend_chart" height="200" style="width:100%"/>
                <div class="o_chart_months">
                    <t t-foreach="state.data.monthly_spend" t-as="m" t-key="m.month">
                        <div class="o_chart_month_val">
                            <div class="o_cmonth_val">$<t t-esc="fmtMoney(m.value)"/></div>
                            <div class="o_cmonth_lbl"><t t-esc="m.count"/> receipts</div>
                        </div>
                    </t>
                </div>
            </div>

            <div class="o_panel">
                <div class="o_panel_hd">
                    <h3>🏆 Top Products by Spend</h3>
                    <button class="o_panel_link"
                        t-on-click="() => this.navigateTo('medical_inventory.action_receive_analytics')">
                        Full Report →
                    </button>
                </div>
                <t t-if="state.data.top_products.length === 0">
                    <div class="o_empty">No purchase history yet.</div>
                </t>
                <t t-foreach="state.data.top_products" t-as="p" t-key="p.name">
                    <div class="o_top_row">
                        <div class="o_top_rank"><t t-esc="p_index + 1"/></div>
                        <div class="o_top_info">
                            <span class="o_top_name"><t t-esc="p.name"/></span>
                            <span class="o_top_sub"><t t-esc="fmtMoney(p.qty)"/> units received</span>
                        </div>
                        <div class="o_top_val">$<t t-esc="fmtMoney(p.total)"/></div>
                    </div>
                </t>
            </div>
        </div>

        <!-- Recent Receipts -->
        <div class="o_panel o_rec_panel">
            <div class="o_panel_hd">
                <h3>🚚 Recent Deliveries</h3>
                <button class="o_panel_link"
                    t-on-click="() => this.navigateTo('medical_inventory.action_stock_receive')">
                    View All →
                </button>
            </div>
            <t t-if="state.data.recent_receipts.length === 0">
                <div class="o_empty">No receipts yet.</div>
            </t>
            <div class="o_rec_grid">
                <t t-foreach="state.data.recent_receipts" t-as="r" t-key="r.name">
                    <div class="o_rec_card">
                        <div class="o_rec_ref"><t t-esc="r.name"/></div>
                        <div class="o_rec_vendor">🏪 <t t-esc="r.vendor"/></div>
                        <div class="o_rec_loc">📍 <t t-esc="r.location"/></div>
                        <div class="o_rec_date">📅 <t t-esc="r.date"/></div>
                        <div class="o_rec_val">$<t t-esc="fmtMoney(r.value)"/></div>
                    </div>
                </t>
            </div>
        </div>

    </t>
</div>
</t>
</templates>
