<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ===== PURCHASE ANALYTICS ===== -->
    <record id="view_receive_graph" model="ir.ui.view">
        <field name="name">medical.receive.line.graph</field>
        <field name="model">medical.stock.receive.line</field>
        <field name="arch" type="xml">
            <graph string="Spend by Product" type="bar" sample="1">
                <field name="product_id" type="row"/>
                <field name="subtotal" type="measure" string="Total Spend"/>
                <field name="quantity" type="measure"/>
            </graph>
        </field>
    </record>

    <record id="view_receive_pivot" model="ir.ui.view">
        <field name="name">medical.receive.line.pivot</field>
        <field name="model">medical.stock.receive.line</field>
        <field name="arch" type="xml">
            <pivot string="Purchase Analytics" sample="1" display_quantity="true">
                <field name="product_id" type="row" string="Product"/>
                <field name="quantity" type="measure" string="Qty Purchased"/>
                <field name="unit_price" type="measure" string="Avg Unit Price"/>
                <field name="subtotal" type="measure" string="Total Spend"/>
            </pivot>
        </field>
    </record>

    <record id="view_receive_line_list" model="ir.ui.view">
        <field name="name">medical.receive.line.list</field>
        <field name="model">medical.stock.receive.line</field>
        <field name="arch" type="xml">
            <list string="Purchase History">
                <field name="receive_id" string="Receipt"/>
                <field name="product_id" string="Product"/>
                <field name="quantity" sum="Total Qty"/>
                <field name="product_uom_id" string="Unit"/>
                <field name="unit_price" string="Unit Price" avg="Avg Price"/>
                <field name="subtotal" string="Total" sum="Grand Total"/>
                <field name="expiry_date" optional="show"/>
            </list>
        </field>
    </record>

    <record id="view_receive_line_search" model="ir.ui.view">
        <field name="name">medical.receive.line.search</field>
        <field name="model">medical.stock.receive.line</field>
        <field name="arch" type="xml">
            <search string="Search Purchases">
                <field name="product_id"/>
                <field name="receive_id"/>
                <filter string="This Month" name="this_month"
                        domain="[('receive_id.date_receive','&gt;=',(context_today()).strftime('%Y-%m-01'))]"/>
                <filter string="Last Month" name="last_month"
                        domain="[('receive_id.date_receive','&gt;=',(context_today()-relativedelta(months=1)).strftime('%Y-%m-01')),
                                  ('receive_id.date_receive','&lt;',(context_today()).strftime('%Y-%m-01'))]"/>
                <filter string="This Year" name="this_year"
                        domain="[('receive_id.date_receive','&gt;=',(context_today()).strftime('%Y-01-01'))]"/>
                <filter string="Last 30 Days" name="last_30"
                        domain="[('receive_id.date_receive','&gt;=',(context_today()-datetime.timedelta(days=30)).strftime('%Y-%m-%d'))]"/>
                <separator/>
                <filter string="By Product" name="group_product" context="{'group_by': 'product_id'}"/>
                <filter string="By Month" name="group_month"
                        context="{'group_by': 'date_receive:month'}"/>
                <filter string="By Location" name="group_location"
                        context="{'group_by': 'destination_location_id'}"/>
                <filter string="By Vendor" name="group_vendor"
                        context="{'group_by': 'vendor_id'}"/>
            </search>
        </field>
    </record>

    <record id="action_receive_analytics" model="ir.actions.act_window">
        <field name="name">Purchase Analytics</field>
        <field name="res_model">medical.stock.receive.line</field>
        <field name="view_mode">graph,pivot,list</field>
        <field name="search_view_id" ref="view_receive_line_search"/>
        <field name="domain">[('receive_id.state', '=', 'done')]</field>
        <field name="context">{'search_default_group_product': 1}</field>
    </record>

    <!-- ===== CONSUMPTION ANALYTICS ===== -->
    <record id="view_consumption_line_graph" model="ir.ui.view">
        <field name="name">medical.consumption.line.graph</field>
        <field name="model">medical.consumption.request.line</field>
        <field name="arch" type="xml">
            <graph string="Consumption by Product" type="bar" sample="1">
                <field name="product_id" type="row"/>
                <field name="quantity" type="measure" string="Units Consumed"/>
            </graph>
        </field>
    </record>

    <record id="view_consumption_line_pivot" model="ir.ui.view">
        <field name="name">medical.consumption.line.pivot</field>
        <field name="model">medical.consumption.request.line</field>
        <field name="arch" type="xml">
            <pivot string="Consumption Analytics" sample="1" display_quantity="true">
                <field name="product_id" type="row" string="Product"/>
                <field name="department_location_id" type="col" string="Clinic"/>
                <field name="quantity" type="measure" string="Units Consumed"/>
            </pivot>
        </field>
    </record>

    <record id="view_consumption_line_list" model="ir.ui.view">
        <field name="name">medical.consumption.line.list</field>
        <field name="model">medical.consumption.request.line</field>
        <field name="arch" type="xml">
            <list string="Consumption History">
                <field name="date_request" string="Date"/>
                <field name="request_id" string="Request"/>
                <field name="department_location_id" string="Clinic"/>
                <field name="product_id" string="Product"/>
                <field name="quantity" sum="Total Consumed"/>
                <field name="product_uom_id" string="Unit"/>
            </list>
        </field>
    </record>

    <record id="view_consumption_line_search" model="ir.ui.view">
        <field name="name">medical.consumption.line.search</field>
        <field name="model">medical.consumption.request.line</field>
        <field name="arch" type="xml">
            <search string="Search Consumption">
                <field name="product_id"/>
                <field name="department_location_id"/>
                <filter string="This Month" name="this_month"
                        domain="[('date_request','&gt;=',(context_today()).strftime('%Y-%m-01'))]"/>
                <filter string="Last Month" name="last_month"
                        domain="[('date_request','&gt;=',(context_today()-relativedelta(months=1)).strftime('%Y-%m-01')),
                                  ('date_request','&lt;',(context_today()).strftime('%Y-%m-01'))]"/>
                <filter string="This Year" name="this_year"
                        domain="[('date_request','&gt;=',(context_today()).strftime('%Y-01-01'))]"/>
                <filter string="Last 30 Days" name="last_30"
                        domain="[('date_request','&gt;=',(context_today()-datetime.timedelta(days=30)).strftime('%Y-%m-%d'))]"/>
                <separator/>
                <filter string="By Product" name="group_product" context="{'group_by': 'product_id'}"/>
                <filter string="By Clinic" name="group_clinic" context="{'group_by': 'department_location_id'}"/>
                <filter string="By Month" name="group_month" context="{'group_by': 'date_request:month'}"/>
            </search>
        </field>
    </record>

    <record id="action_consumption_analytics" model="ir.actions.act_window">
        <field name="name">Consumption Analytics</field>
        <field name="res_model">medical.consumption.request.line</field>
        <field name="view_mode">graph,pivot,list</field>
        <field name="search_view_id" ref="view_consumption_line_search"/>
        <field name="domain">[('request_id.state','=','done'),('request_id.request_type','=','consumption')]</field>
        <field name="context">{'search_default_group_product': 1}</field>
    </record>

    <!-- ===== EXPIRY MONITOR ===== -->
    <record id="view_expiry_monitor_list" model="ir.ui.view">
        <field name="name">medical.expiry.monitor.list</field>
        <field name="model">medical.stock.receive.line</field>
        <field name="arch" type="xml">
            <list string="Expiry Monitor"
                  decoration-danger="expiry_date and expiry_date &lt;= current_date"
                  decoration-warning="expiry_date != False">
                <field name="product_id" string="Product"/>
                <field name="quantity" string="Qty" sum="Total"/>
                <field name="product_uom_id" string="Unit"/>
                <field name="expiry_date" string="Expiry Date"/>
                <field name="lot_id" optional="show" string="Batch"/>
                <field name="receive_id" string="From Receipt"/>
            </list>
        </field>
    </record>

    <record id="action_expiry_monitor" model="ir.actions.act_window">
        <field name="name">Expiry Monitor</field>
        <field name="res_model">medical.stock.receive.line</field>
        <field name="view_mode">list</field>
        <field name="view_id" ref="view_expiry_monitor_list"/>
        <field name="domain">[('expiry_date','!=',False),('receive_id.state','=','done')]</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">✅ No expiry alerts</p>
        </field>
    </record>

</odoo>
