<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_analytics_report_form" model="ir.ui.view">
        <field name="name">medical.analytics.report.form</field>
        <field name="model">medical.analytics.report</field>
        <field name="arch" type="xml">
            <form string="Generate Report">
                <sheet>
                    <div class="oe_title">
                        <h2>📊 Generate Analytics Report</h2>
                    </div>
                    <group>
                        <group string="Report Settings">
                            <field name="report_type" widget="radio"/>
                            <field name="export_format" widget="radio"/>
                        </group>
                        <group string="Filters">
                            <field name="date_from"/>
                            <field name="date_to"/>
                            <field name="location_id"/>
                            <field name="product_id"/>
                        </group>
                    </group>

                    <div class="alert alert-info" invisible="export_format != 'pdf'" role="alert">
                        <strong>PDF Note:</strong> PDF export requires ReportLab.
                        If it fails, run: <code>pip install reportlab</code> on your server,
                        or use Excel which works without any installation.
                    </div>
                    <div invisible="state != 'done'" class="alert alert-success" role="alert">
                        <strong>✅ Report ready!</strong> Click the download button below.
                    </div>

                    <group invisible="state != 'done'">
                        <field name="file_data" filename="file_name" widget="binary"
                               string="Download Report"/>
                        <field name="file_name" invisible="1"/>
                    </group>

                    <footer>
                        <button name="action_generate" string="Generate Report"
                                type="object" class="btn-primary"
                                invisible="state == 'done'"/>
                        <button name="action_generate" string="Regenerate"
                                type="object" class="btn-secondary"
                                invisible="state != 'done'"/>
                        <button string="Close" class="btn-secondary" special="cancel"/>
                    </footer>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_analytics_report_wizard" model="ir.actions.act_window">
        <field name="name">Generate Report</field>
        <field name="res_model">medical.analytics.report</field>
        <field name="view_mode">form</field>
        <field name="view_id" ref="view_analytics_report_form"/>
        <field name="target">new</field>
    </record>

</odoo>
