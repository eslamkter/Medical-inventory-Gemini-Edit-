<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_medical_products_list" model="ir.ui.view">
        <field name="name">medical.products.list</field>
        <field name="model">product.product</field>
        <field name="arch" type="xml">
            <list string="Products"
                  decoration-warning="type == 'consu'"
                  decoration-danger="type == 'service'">
                <field name="default_code" string="Ref" optional="show"/>
                <field name="name" string="Product Name"/>
                <field name="categ_id" string="Category" optional="show"/>
                <field name="uom_id" string="Unit"/>
                <field name="standard_price" string="Cost Price"/>
                <field name="type" string="Product Type" widget="badge"
                       decoration-success="type in ('product', 'storable')"
                       decoration-warning="type == 'consu'"
                       decoration-danger="type == 'service'"/>
            </list>
        </field>
    </record>

    <record id="view_medical_products_search" model="ir.ui.view">
        <field name="name">medical.products.search</field>
        <field name="model">product.product</field>
        <field name="arch" type="xml">
            <search string="Search Products">
                <field name="name"/>
                <field name="default_code"/>
                <field name="categ_id"/>
                <filter string="✅ Storable (tracked in stock)" name="storable"
                        domain="[('type','in',['product','storable'])]"/>
                <filter string="⚠️ Consumable (NOT tracked)" name="consumable"
                        domain="[('type','=','consu')]"/>
                <separator/>
                <filter string="By Category" name="group_categ"
                        context="{'group_by': 'categ_id'}"/>
                <filter string="By Type" name="group_type"
                        context="{'group_by': 'type'}"/>
            </search>
        </field>
    </record>

    <record id="action_medical_products" model="ir.actions.act_window">
        <field name="name">Products</field>
        <field name="res_model">product.product</field>
        <field name="view_mode">list,form</field>
        <field name="view_id" ref="view_medical_products_list"/>
        <field name="search_view_id" ref="view_medical_products_search"/>
        <field name="domain">[('type', 'in', ['product', 'consu'])]</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">No products yet</p>
            <p>
                ⚠️ Products must be set as <strong>Storable</strong> (not Consumable)
                to be tracked in stock. Check the Product Type column —
                green = Storable ✅, orange = Consumable ⚠️
            </p>
        </field>
    </record>

</odoo>
